#if !defined(AFX_MMCMANAGER_H__D8D8CB42_7AB7_4305_A66A_EDD00C6DD663__INCLUDED_)
#define AFX_MMCMANAGER_H__D8D8CB42_7AB7_4305_A66A_EDD00C6DD663__INCLUDED_

#if _MSC_VER > 1000
#pragma once
#endif // _MSC_VER > 1000


#include "MMCDef.h"

#pragma warning(disable: 4200) 
#pragma warning(disable: 4996) 

//#####################//
//### VERSION 확인 ####//
//#####################//

#define MMC_DIS_VER_CSIM		MMC_CMD_CSIM + 1

// packing is now 1
#pragma pack(push, 1)

typedef struct {
	char cSide;	// A(0), B(1), ACTIVE(2)
} IMD_34001;

typedef struct {
	char szVersion[10];
	char szLastUpdateDate[20];
	char szLastUpdateUser[20];
	char szDescription[128];
} OMD_34001;

#pragma pack(pop)
// packing is now old size

/*

    CURRENT VERSION  : 1.0.0
    LAST UPDATE DATE : 2004.08.20
    LAST UPDATE USER : 김인수
    DESCRIPTION :
              최초 버젼관리
*/

//###############################//
//### SGM, CGM 세션 연결상태 ####//
//###############################//

#define MMC_DIS_STA_CSIM		MMC_CMD_CSIM + 2

// packing is now 1
#pragma pack(push, 1)

typedef struct {
	char cSide;	// A(0), B(1), ACTIVE(2)
} IMD_34002;

typedef struct {
	char cAS;
	char cType;		// CGM_A(0), CGM_B(1), SGM_A(2), SGM_B(3), Etc(4)
	char cState;	// disconnected(0), connected(1)
	char szIP[16];
	long tConnected;
	unsigned long nReqCount;
	unsigned long nAckCount;
	unsigned long nErrCount;
} OMD_34002_ITEM;

typedef struct {
	char cHAStatus;	// UNDEFINED(0), ACTIVE(1), STANDBY(2)
	char cCount;
	OMD_34002_ITEM item[];
} OMD_34002;

#pragma pack(pop)
// packing is now old size

/*
	AS  MOD    STATUS      IP          CONN_TIME                REQ    ACK
	 0  CGM_A  CONNECTED   127.0.0.1   2005.05.10 11:12:21    50231  50231

*/


// 처리 상태
// DBMS 연결 상태



//#################################//
//### LOG LEVEL 설정 ####//
//#################################//

#define MMC_SET_LOGLV_CSIM      MMC_CMD_CSIM + 201

// packing is now 1
#pragma pack(push, 1)

typedef struct {
	char cSide;	// A(0), B(1), ACTIVE(2)
	unsigned char ucTraceLevel;
} IMD_34201;

typedef struct {
	char cBeforeLogLevel;	
	char cChangedLogLevel;	
} OMD_34201;

#pragma pack(pop)


class CMMCManager  
{
protected:
	static bool cmd_VersionInfo(int nFrom, MMC_HEAD* pHead, u_pchar pData);
	static bool cmd_SessionStatusInfo(int nFrom, MMC_HEAD* pHead, u_pchar pData);

	static bool cmd_SetLogLevel(int nFrom, MMC_HEAD* pHead, u_pchar pData);

public:
	CMMCManager();
	virtual ~CMMCManager();

	bool initialize(void);
	void uninitialize(void);

	friend CMMCManager& theMMCManager(void);
};

extern CMMCManager& theMMCManager(void);

#endif // !defined(AFX_MMCMANAGER_H__D8D8CB42_7AB7_4305_A66A_EDD00C6DD663__INCLUDED_)

