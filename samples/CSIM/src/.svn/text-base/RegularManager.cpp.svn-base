bool CRegularManager::insertDGMSts(const char cASID, unsigned char cModuleID, const char* szStartDate, const char* szEndDate, DGM_STS_ORG* pData)
{
	char* pSql;

	pSql = (char*)malloc(2048);

	sprintf(pSql, "INSERT INTO TBL_DGM_STAT "
			"(START_TIME"
			",END_TIME"
			",AS_IDX"
			",MODULE_CODE"
			",Bind_Req, Bind_Success, Bind_Fail "
			",Deliver_Req, Deliver_Success, Deliver_Fail "
			",Report_Success, Report_Invalid, Report_Poweroff, Report_Hidden, Report_TermFull, Report_Etc "
			",RingId_Req, RingId_Success, RingId_Fail )"
		" VALUES"
			"('%s'"
			",'%s'"
			",%d"
			",%d"
			",%d ,%d ,%d "
			",%d ,%d ,%d "
			",%d ,%d ,%d ,%d ,%d ,%d "
			",%d ,%d ,%d )", 
			szStartDate,
			szEndDate,
			cASID,
			cModuleID,
			(*pData).Bind_Req, (*pData).Bind_Success, (*pData).Bind_Fail,
			(*pData).Deliver_Req, (*pData).Deliver_Success, (*pData).Deliver_Fail,
			(*pData).Report_Success, (*pData).Report_Invalid, (*pData).Report_Poweroff, (*pData).Report_Hidden, (*pData).Report_TermFull, (*pData).Report_Etc,
			(*pData).RingId_Req, (*pData).RingId_Success, (*pData).RingId_Fail);

	std::string sResultValue;
	bool bResult;

	bResult = m_occi.sqlExecute(pSql, sResultValue);

	LOGGER(TRACE_LEVEL1, "regular manager[%d] : DGM statistic insert \n %s", m_nIndex, pSql);

	free(pSql);

	return bResult;
}

