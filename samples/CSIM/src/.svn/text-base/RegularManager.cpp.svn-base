	bResult = m_occi.sqlExecute(pSql, sResultValue);

	LOGGER(TRACE_LEVEL1, "regular manager[%d] : SAM statistic insert \n %s", m_nIndex, pSql);

	free(pSql);

	return bResult;
}

bool CRegularManager::insertSRMSts(const char cASID, unsigned char cModuleID, const char* szStartDate, const char* szEndDate, SRM_STS_ORG* pData, int nLength)
{
	char* pSql;
	std::string sResultValue;
	bool bResult;

	pSql = (char*)malloc(2048);
	memset(pSql, 0x00 , 2048);

	while(nLength > 0)
	{

		sprintf(pSql, "INSERT INTO TBL_SRM_STAT "
				"(START_TIME"
				",END_TIME"
				",AS_IDX"
				",MODULE_CODE"
				",AS_SVC_CODE, SSW_ID "
				",USER_DEFINE1, USER_DEFINE2, USER_DEFINE3, USER_DEFINE4, USER_DEFINE5 "
				",USER_DEFINE6, USER_DEFINE7, USER_DEFINE8, USER_DEFINE9, USER_DEFINE10 "
				",USER_DEFINE11, USER_DEFINE12, USER_DEFINE13, USER_DEFINE14, USER_DEFINE15 "
				",USER_DEFINE16, USER_DEFINE17, USER_DEFINE18, USER_DEFINE19, USER_DEFINE20 "
				",USER_DEFINE21, USER_DEFINE22, USER_DEFINE23, USER_DEFINE24, USER_DEFINE25 "
				",USER_DEFINE26, USER_DEFINE27, USER_DEFINE28, USER_DEFINE29, USER_DEFINE30 )"
			" VALUES"
				"('%s'"
				",'%s'"
				",%d"
				",%d"
				",'%.16s'"
				",%u "
				",%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u "
				",%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u "
				",%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u ,%u )", 
				szStartDate,
				szEndDate,
				cASID,
				cModuleID,
				(*pData).svcCode,
				(*pData).ssw_id,
				(*pData).userdef[0],
				(*pData).userdef[1],
				(*pData).userdef[2],
				(*pData).userdef[3],
				(*pData).userdef[4],
				(*pData).userdef[5],
				(*pData).userdef[6],
				(*pData).userdef[7],
				(*pData).userdef[8],
				(*pData).userdef[9],
				(*pData).userdef[10],
				(*pData).userdef[11],
				(*pData).userdef[12],
				(*pData).userdef[13],
				(*pData).userdef[14],
				(*pData).userdef[15],
				(*pData).userdef[16],
				(*pData).userdef[17],
				(*pData).userdef[18],
				(*pData).userdef[19],
				(*pData).userdef[20],
				(*pData).userdef[21],
				(*pData).userdef[22],
				(*pData).userdef[23],
				(*pData).userdef[24],
				(*pData).userdef[25],
				(*pData).userdef[26],
				(*pData).userdef[27],
				(*pData).userdef[28],
				(*pData).userdef[29] );


		sResultValue = "";

		LOGGER(TRACE_LEVEL1, "regular manager[%d] : SRM statistic insert \n %s", m_nIndex, pSql);
		bResult = m_occi.sqlExecute(pSql, sResultValue);
		if(!bResult) break;

		nLength -= sizeof(SRM_STS_ORG);
		pData++;
	}

	free(pSql);

	return bResult;
}

