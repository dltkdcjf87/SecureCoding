//////////////////////////////////////////////////////////////////////
// Construction/Destruction
//////////////////////////////////////////////////////////////////////

CRegularManager::CRegularManager(int nIdx)
{
	m_hThread = 0;
	m_nIndex = nIdx;

}

CRegularManager::~CRegularManager()
{

}

void CRegularManager::initialize(void)
{
	char szUserID[32];
	char szPasswd[32];
	char szConnStr[32];

	GetPrivateProfileString("CSIM", "ORACLE_USERID", "sysdba", szUserID, sizeof(szUserID), theGlobal().getCSIMConfigFile()); 
	GetPrivateProfileString("CSIM", "ORACLE_PASSWD", "oracle", szPasswd, sizeof(szPasswd), theGlobal().getCSIMConfigFile()); 
	GetPrivateProfileString("CSIM", "ORACLE_CONNSTR", "", szConnStr, sizeof(szConnStr), theGlobal().getCSIMConfigFile()); 

	m_occi.initialize(szUserID, szPasswd, szConnStr);

}

void CRegularManager::start(void)
{
	u_long ulThreadID = 0;

	if(m_hThread != 0) return;

	_CreateThread(m_hThread, NULL, 0, (LPTHREAD_START_ROUTINE) CRegularManager::executeThread, (LPVOID)this, 0, &ulThreadID);

	if(m_hThread == null) {
		LOGGER(TRACE_ERROR, "regular manager : create thread 1 fail. [%ld]", GetLastError());
	
		return;
	}
}

unsigned long CRegularManager::executeThread(LPVOID param)
{
	CRegularManager* pThis = (CRegularManager*) param;

	(*pThis).main();

	return 0;
}

void CRegularManager::main(void)
{
	IFString streamBuff('\1', '\2', 6, 2048);
	CSIM_TCP_HEAD csimHead;
	SessionStream stmClient(false);
	CMsgQueue::_MSG_ msg;
	SESSION_INFO session;
	int bOk;

	LOGGER(TRACE_INFO, "regular manager[%d] : daemon start. ", m_nIndex);

	csimHead.nLength = sizeof(CSIM_TCP_HEAD);

	while(true)
	{
		bOk = theServiceDaemon().getMsg(msg);	
		if(bOk == false) continue;

		if(!theServiceDaemon().findSessionInfo(msg.nParam, &session))
		{
			msg.clear();
			theServiceDaemon().incFailCount(msg.nParam);
			continue;
		}

		stmClient.set(session.handle, sessionTypeTCP);

		csimHead.nAsCode = session.nAS;
		csimHead.nModule = 0;
		csimHead.nMsgId = msg.id;

		if(m_occi.isConnect()) {

			if(msg.id == statisticMessageID) {
				bOk = stsRegist(session.nAS, msg.pData, msg.nLength);

				if(bOk) {
					m_occi.commit();
					csimHead.result = successCode;
					csimHead.reason = reasonOk;
				} else {
					csimHead.result = failCode;

					if(m_occi.isConnect()) csimHead.reason = csimDataWrong;
					else csimHead.reason = dbmsDisconnect;
				}

				LOGGER(TRACE_LEVEL2, "regular manager[%d] : statistic process response sent", m_nIndex);
			} else {
				csimHead.result = failCode;
				csimHead.reason = csimIDWrong;
			}
		} else {
#if !defined(WIN32)
			csimHead.result = failCode;
			csimHead.reason = dbmsDisconnect;
#else
			csimHead.result = successCode;
			csimHead.reason = reasonOk;
#endif
		}

		streamBuff.clear();
		streamBuff.append(sizeof(CSIM_TCP_HEAD), (char*)&csimHead);

		try {
			stmClient.send(&streamBuff);

			theServiceDaemon().incAckCount(msg.nParam);
		} catch(const char* errMsg) {
			stmClient.disconnect();
			LOGGER(TRACE_ERROR, "regular manager[%d] : cdr response send fail : %s", m_nIndex, errMsg);

			theServiceDaemon().incFailCount(msg.nParam);
		}

		msg.clear();
	}
}

bool CRegularManager::stsRegist(const char cASID, const char* pData, int nLength)
{
	STS_CSIM_HEAD* pHead;
	char* pBody;
	unsigned char cModuleID;
	int nIndex, nDataLen;
	int nTotalSize = 0;
	bool bResult;
	
	LOGGER(TRACE_LEVEL2, "regular manager[%d] : statistic processing (len:%d)", m_nIndex, nLength);

	while(nTotalSize < nLength)
	{
		nIndex = *((int*)pData);
		pData += sizeof(int);
		nDataLen = *((int*)pData);
		pData += sizeof(int);

		pHead = (STS_CSIM_HEAD*)pData;
		pBody = (char*)pData + sizeof(STS_CSIM_HEAD);
		pData += nDataLen;

		nTotalSize += (nDataLen + sizeof(int) + sizeof(int));

		if(nDataLen == 0) continue;

		cModuleID = (*pHead).nModuleID;

		if(cModuleID == SCM || cModuleID == SCM_A || cModuleID == SCM_B) {
			if((*pHead).nID == 0) {
				bResult = insertSCMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SCM_STS_ORG*)pBody);
			} else if((*pHead).nID == 1) {
				bResult = insertSCM2Sts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SCM_BD_STS_ORG*)pBody, nDataLen-sizeof(STS_CSIM_HEAD));
			} else return false;
		} else if(cModuleID == SPY || cModuleID == SPY_A || cModuleID == SPY_B) {
			bResult = insertSPYSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SPY_STS_ORG*)pBody);
		} else if(cModuleID >= SAM_00 && cModuleID <= SAM_00+15) {
			bResult = insertSAMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SAM_STS_ORG*)pBody);
		} else if(cModuleID >= SRM_00 && cModuleID <= SRM_00+15) {
			bResult = insertSRMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SRM_STS_ORG*)pBody, nDataLen-sizeof(STS_CSIM_HEAD));
		} else if(cModuleID == DBM || cModuleID == DBM_A || cModuleID == DBM_B) {
//			bResult = insertDBMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (DBM_STS_ORG*)pBody, nDataLen-sizeof(STS_CSIM_HEAD));
			bResult = true;
		} else if(cModuleID == MGM || cModuleID == MGM_A || cModuleID == MGM_B) {
//			bResult = insertMGMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (MGM_STS_ORG*)pBody);
			bResult = true;
		} else if(cModuleID == CGM || cModuleID == CGM_A || cModuleID == CGM_B) {
//			bResult = insertCGMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (CGM_STS_ORG*)pBody);
			bResult = true;
		} else if(cModuleID == SGM || cModuleID == SGM_A || cModuleID == SGM_B) {
//			bResult = insertSGMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (SGM_STS_ORG*)pBody);
			bResult = true;
		} else if(cModuleID == DGM || cModuleID == DGM_A || cModuleID == DGM_B) {
			bResult = insertDGMSts(cASID, cModuleID, (*pHead).start_time, (*pHead).end_time, (DGM_STS_ORG*)pBody);
			bResult = true;
		}

		if(!bResult) break;
	}
	
	return bResult;
}

bool CRegularManager::insertSCMSts(const char cASID, unsigned char cModuleID, const char* szStartDate, const char* szEndDate, SCM_STS_ORG* pData)
{
	char* pSql;

	pSql = (char*)malloc(2048);

	sprintf(pSql, "INSERT INTO TBL_SCM_STAT "
			"(START_TIME"
			",END_TIME"
			",AS_IDX"
			",MODULE_CODE"
			",TOTAL_CH"
			",BUSY_CH"
			",BLOCK_CH"
			",T_ALLOC"
			",SPY_ALLOC"
			",SRM_ALLOC"
			",DE_ALLOC"
			",T_FAIL"
			",SPY_FAIL1"
			",SPY_FAIL2"
			",SPY_FAIL3"
			",SPY_FAIL4"
			",SPY_FAIL5"
			",SRM_FAIL)"
		" VALUES"
			"('%s'"
			",'%s'"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d )", 
			szStartDate,
			szEndDate,
			cASID,
			cModuleID,
			(*pData).total_ch,
			(*pData).busy_ch,
			(*pData).block_ch,
			(*pData).t_Alloc,
			(*pData).spyAlloc,
			(*pData).srmAlloc,
			(*pData).deAlloc,
			(*pData).t_Fail,
			(*pData).spyFail[0],
			(*pData).spyFail[1],
			(*pData).spyFail[2],
			(*pData).spyFail[3],
			(*pData).spyFail[4],
			(*pData).srmFail);

	std::string sResultValue;
	bool bResult;

	bResult = m_occi.sqlExecute(pSql, sResultValue);

	LOGGER(TRACE_LEVEL1, "regular manager[%d] : SCM statistic insert \n %s", m_nIndex, pSql);

	free(pSql);

	return bResult;
}

bool CRegularManager::insertSCM2Sts(const char cASID, unsigned char cModuleID, const char* szStartDate, const char* szEndDate, SCM_BD_STS_ORG* pData, int nLength)
{
	char* pSql;

	pSql = (char*)malloc(2048);

	sprintf(pSql, "INSERT INTO TBL_SCM_BD_STAT "
			"(START_TIME"
			",END_TIME"
			",AS_IDX"
			",MODULE_CODE"
			",TOTAL_CH"
			",BUSY_CH"
			",BLOCK_CH)"
		" VALUES"
			"('%s'"
			",'%s'"
			",%d"
			",%d"
			",%d"
			",%d"
			",%d)", 
			szStartDate,
			szEndDate,
			cASID,
			cModuleID,
			(*pData).total_ch,
			(*pData).busy_ch,
			(*pData).block_ch);

	std::string sResultValue;
	bool bResult;

	bResult = m_occi.sqlExecute(pSql, sResultValue);
	
	LOGGER(TRACE_LEVEL1, "regular manager[%d] : SCM2 statistic insert \n %s", m_nIndex, pSql);

	free(pSql);

	return bResult;
}

