//////////////////////////////////////////////////////////////////////
// Construction/Destruction
//////////////////////////////////////////////////////////////////////

CServiceDaemon& theServiceDaemon(void)
{
	static CServiceDaemon theSvcDaemon(sessionTypeTCP);

	return theSvcDaemon;
}

CServiceDaemon::CServiceDaemon(SessionType type)
 : SessionServer(type)
{

}

CServiceDaemon::~CServiceDaemon()
{
	DeleteCriticalSection(&m_CriticalSection);
}

bool CServiceDaemon::init(void)
{
	m_messageQueue.initialize();

	InitializeCriticalSection(&m_CriticalSection);

	return true;
}

bool CServiceDaemon::daemonStart(int nPort)
{
	try {
		Using(null, nPort);
		SessionServer::start();
	} catch(const char* errMsg) {
		LOGGER(TRACE_ERROR, "service daemon start fail : %s.", errMsg);
		return false;
	}

	LOGGER(TRACE_LEVEL2, "service daemon started. (port:%d)", nPort);

	return true;
}

bool CServiceDaemon::daemonStop(void)
{
	return stop();
}


bool CServiceDaemon::OnConnect(SESSION_HANDLER handler, const char* ip)
{
	LOGGER(TRACE_LEVEL1, "tcp connected : %s(%d)", ip, handler);
	return true;
}

bool CServiceDaemon::OnDisconnect(SESSION_HANDLER handler, const char* ip)
{
	LOGGER(TRACE_LEVEL1, "tcp disconnected : %s(%d)", ip, handler);

	sessionUnRegist(handler);

	return true;
}

bool CServiceDaemon::OnReceive(SESSION_HANDLER handler, const char* ip)
{
	SessionStream stmClient(false);
	IFString data('\1', '\2', 6, 1024 * 40);

	try {
		stmClient.set(handler, sessionTypeTCP);
		stmClient.receive(&data);
	} catch(const char* errMsg) {
		LOGGER(TRACE_ERROR, "tcp(%d) : %s", handler, errMsg);
		return false;
	}

	char* pData = data.getBuff();
	int nLength = data.length();

	if(nLength < sizeof(CSIM_TCP_HEAD)) {
		LOGGER(TRACE_ERROR, "tcp(%d) : size small", handler);
		LOGGER_HEX(pData, nLength);
		// size error
		return false;
	}

	CSIM_TCP_HEAD* pHead = (CSIM_TCP_HEAD*)pData;
	int nID;
	bool bResult;
	char* pBuff;

	nID = (*pHead).nMsgId;

	switch(nID) {
	case sessionRegistID :
		bResult = sessionRegist(handler, (*pHead).nAsCode, (*pHead).nModule, ip);

		(*pHead).result = successCode;
		(*pHead).reason = reasonOk;

		if(bResult == false) {
			sessionUnRegist(handler);
		}

		
		try {
			stmClient.send(&data);
		} catch(const char* errMsg) {
			LOGGER(TRACE_ERROR, "regist response send fail tcp(%d) : %s", handler, errMsg);
			return false;
		}

		if(bResult == false) return false;

		break;
	case statisticMessageID :
		if(!theSRManager().isActive()) return true;

		incRequestCount(handler);

		pData += sizeof(CSIM_TCP_HEAD);
		nLength -= sizeof(CSIM_TCP_HEAD);

		putEvent(handler, nID, pData, nLength);
		break;
	case queryMessageID :
		if(!theSRManager().isActive()) return true;

		incRequestCount(handler);

		pData += sizeof(CSIM_TCP_HEAD);
		nLength -= sizeof(CSIM_TCP_HEAD);

		pBuff = (char*) theUtility().clon((void*)pData, nLength);

		theQueueMgr().putMsg(0 /* tcp:0, xbus:1*/, pBuff, nLength, handler /* tcp:sock_handle, xbus:module_id*/);
		LOGGER(TRACE_LEVEL1, "dynamic query add queue.");
		break;
	case heartBeatMessageID :
		(*pHead).result = successCode;
		(*pHead).reason = reasonOk;

		try {
			stmClient.send(&data);
		} catch(const char* errMsg) {
			LOGGER(TRACE_ERROR, "heartbeat response send fail tcp(%d) : %s", handler, errMsg);
			return false;
		}
		break;
	default :
		LOGGER(TRACE_ERROR, "tcp(%d) : no define id(%d)", handler, nID);
	}

	return true;
}

//####################################################//
//## 2005.04.19 chiwoo CGM, SGM¿« ¡¢º”¿ª µÓ∑œ«—¥Ÿ.  ##//
//##                                                ##//  
//####################################################//
bool CServiceDaemon::sessionRegist(SESSION_HANDLER handle, int nAS, int nModule, const char* szIP)
{
	int nGroupCode;

	if(nModule == SGM_A || nModule == SGM_B) {
		nGroupCode = SGM;
	} else {
		LOGGER(TRACE_WARNNING, "this module(0x%0x02x) is not support, only support SGM. (hd:%d)", nModule, handle);
		return false;
	}

	//===================================================//
	//===================================================//
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);
	if(lt != m_mapSessions.end()) {
		LOGGER(TRACE_WARNNING, "this handler(%d) is already register. (md:0x%0x02x)", handle, nModule);
		unlock();
		return false;
	}

	SESSION_INFO* pInfo = new SESSION_INFO;

	m_mapSessions[handle] = pInfo;

	(*pInfo).handle = handle;
	(*pInfo).nAS = nAS;
	(*pInfo).nGroupCode = nGroupCode;
	(*pInfo).nModule = nModule;
	strcpy((*pInfo).szIP, szIP);
	time(&(*pInfo).tConnectTime);
	(*pInfo).lReqCount = (*pInfo).lRespCount = (*pInfo).lFailCount = 0L;

	//===================================================//
	//===================================================//
	char szKey[8];
	SessionMapModule::iterator lt_dual;
	DUALSESSION_INFO* pDualInfo;

	sprintf(szKey, "%02d%02d", nAS, nGroupCode);

	lt_dual = m_mapModuleSessions.find(szKey);
	if(lt_dual == m_mapModuleSessions.end()) {
		pDualInfo = &m_mapModuleSessions[szKey];

		(*pDualInfo).a_side = INVALID_SOCKET;
		(*pDualInfo).b_side = INVALID_SOCKET;
	} else {
		pDualInfo = &(*lt_dual).second;
	}

	int nSideGbn;
	
	if(nModule == SGM_A) {
		(*pDualInfo).a_side = handle;
		nSideGbn = 0;
	} else if(nModule == SGM_B) {
		(*pDualInfo).b_side = handle;
		nSideGbn = 1;
	}
	
	unlock();

	LOGGER(TRACE_INFO, "the module registration success. (as:%d, mod:0x%02x, ip:%s, hd:%d, side:%c)", nAS, nModule, szIP, handle, (nSideGbn==0)?'A':'B');

	return true;
}

//########################################################//
//## 2005.04.19 chiwoo CGM, SGM¿« ¡¢º”«ÿ¡¶¿ª √≥∏Æ«—¥Ÿ.  ##//
//##                                                    ##//  
//########################################################//
bool CServiceDaemon::sessionUnRegist(SESSION_HANDLER handle)
{
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);
	if(lt == m_mapSessions.end()) {
		unlock();
		//LOGGER(TRACE_WARNNING, "this handler(%d) is not found.", handle);
		return false;
	}

	SESSION_INFO* pInfo = (*lt).second;

	LOGGER(TRACE_INFO, "the module unregistration success. (as:%d, mod:0x%02x, ip:%s, hd:%d)", (*pInfo).nAS, (*pInfo).nModule, (*pInfo).szIP, (*pInfo).handle);

	char szKey[8];

	sprintf(szKey, "%02d%02d", (*pInfo).nAS, (*pInfo).nGroupCode);
	
	DUALSESSION_INFO& dualInfo = m_mapModuleSessions[szKey];
	
	if((*pInfo).nModule == CGM_A || (*pInfo).nModule == SGM_A) {
		dualInfo.a_side = INVALID_SOCKET;
	} else if((*pInfo).nModule == CGM_A || (*pInfo).nModule == SGM_A) {
		dualInfo.b_side = INVALID_SOCKET;
	}

	m_mapSessions.erase(lt);
	delete pInfo;

	unlock();

	return true;
}

void CServiceDaemon::putEvent(SESSION_HANDLER handle, int nCmdID, const char* szData, int nLength)
{
	char* pData;

	pData = (char*) theUtility().clon((void*)szData, nLength);

	m_messageQueue.addMsg(nCmdID, (char*)pData, nLength, handle);
//	theRegularMgr().putEvent(handle, nCmdID, pData, nLength);

	return;
}

bool CServiceDaemon::findSessionInfo(SESSION_HANDLER handle, SESSION_INFO* pSessionInfo)
{
	//===================================================//
	//===================================================//
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);
	if(lt == m_mapSessions.end()) {
		unlock();
		return false;
	}

	SESSION_INFO* info = (*lt).second;

	memcpy(pSessionInfo, info, sizeof(SESSION_INFO));

	unlock();

	return true;
}

bool CServiceDaemon::getSessionInfo(int nIdx, int &nAS, unsigned char &cMoID, char *szIP, time_t &tConnected, unsigned long &lReqCnt, unsigned long &lRespCnt, unsigned long &lErrCnt)
{
	SessionMap::iterator lt;

	lock();

	for(lt = m_mapSessions.begin(); lt != m_mapSessions.end() && nIdx > 0; lt++, nIdx--);

	if(lt == m_mapSessions.end()) {
		unlock();
		return false;
	}

	SESSION_INFO* pInfo = (*lt).second;

	nAS = (*pInfo).nAS;
	cMoID = (unsigned char) (*pInfo).nModule;
	strcpy(szIP, (*pInfo).szIP);
	tConnected = (*pInfo).tConnectTime;
	lReqCnt = (*pInfo).lReqCount;
	lRespCnt = (*pInfo).lRespCount;
	lErrCnt = (*pInfo).lFailCount;

	unlock();

	return true;
}

void CServiceDaemon::incRequestCount(SESSION_HANDLER handle)
{
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);

	if(lt == m_mapSessions.end()) {
		unlock();
		return;
	}

	SESSION_INFO* pInfo = (*lt).second;

	(*pInfo).lReqCount++;

	unlock();

	return;
}

void CServiceDaemon::incAckCount(SESSION_HANDLER handle)
{
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);

	if(lt == m_mapSessions.end()) {
		unlock();
		return;
	}

	SESSION_INFO* pInfo = (*lt).second;

	(*pInfo).lRespCount++;

	unlock();

	return;
}

void CServiceDaemon::incFailCount(SESSION_HANDLER handle)
{
	SessionMap::iterator lt;

	lock();

	lt = m_mapSessions.find(handle);

	if(lt == m_mapSessions.end()) {
		unlock();
		return;
	}

	SESSION_INFO* pInfo = (*lt).second;

	(*pInfo).lFailCount++;

	unlock();

	return;
}

